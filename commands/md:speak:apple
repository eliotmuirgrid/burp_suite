md:speak:apple() {
    local file="${1:-i.md}"
    local filter=$2

    [[ "$file" != *.md ]] && file="${file}.md"

    if [[ ! -f "$file" ]]; then
        echo "md:speak:apple: file not found: $file" >&2
        return 1
    fi

    if [[ -n "$filter" ]]; then
       "filter:$filter" "$file" | pandoc -f markdown -t plain | say
    else
       pandoc "$file" -t plain | say
    fi
}
